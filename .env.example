APP_NAME="Khai Tri Edu"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=vi
APP_FALLBACK_LOCALE=vi
APP_FAKER_LOCALE=vi_VN

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mongodb
DB_URI=
DB_HOST=127.0.0.1
DB_PORT=27017
DB_DATABASE=khai_tri_edu
DB_USERNAME=
DB_PASSWORD=
MONGODB_AUTH_SOURCE=admin
MONGODB_REPLICA_SET=
MONGODB_TLS=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=true
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

CACHE_STORE=file
QUEUE_CONNECTION=sync
QUEUE_FAILED_DRIVER=file

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Resend HTTPS API mailer (khuyên dùng trên Render free vì SMTP port 465/587 thường bị block).
# Đăng ký https://resend.com lấy API key, rồi đổi MAIL_MAILER=resend, MAIL_FROM_ADDRESS=onboarding@resend.dev
RESEND_API_KEY=

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_ASSISTANT_MODEL=gemini-2.5-flash-lite

VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_ALLOW_SANDBOX_IN_PRODUCTION=true
VNPAY_EXPIRE_MINUTES=15
VNPAY_LOCALE=vn
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_RETURN_URL=
VNPAY_IPN_URL=
RENDER_RESET_DATABASE=false
RENDER_SEED_DEMO=false
